#    -DWITH_PTHREADS_PF=ON -DENABLE_NEON=ON
#RUN cd /tmp/bazel_build/opencv/release && make -j 16 && make install
RUN --mount=type=cache,target=/tmp/opencv-build \
    cd /tmp/bazel_build/opencv/release && \
    make -j$(nproc) && \
    make install

COPY . /mediapipe/
WORKDIR /mediapipe

