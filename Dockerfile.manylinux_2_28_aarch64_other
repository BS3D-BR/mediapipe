ARG PYTHON_BIN="/opt/python/cp312-cp312/bin/python3.12"
ENV HERMETIC_PYTHON_VERSION=3.12
ENV BAZELISK_HOME=/bazel-cache
RUN mkdir -p /bazel-cache

RUN $PYTHON_BIN -m pip install --upgrade pip setuptools
#RUN $PYTHON_BIN -m pip install wheel "numpy<2" auditwheel torch pyaudio
RUN --mount=type=cache,target=/root/.cache/pip $PYTHON_BIN -m pip install wheel "numpy<2" auditwheel torch

RUN sed -i '/genai\/converter/d' mediapipe/tasks/c/BUILD && \
    sed -i '/genai\/bundler/d' mediapipe/tasks/c/BUILD && \
    sed -i "s/ENABLE_ODML_CONVERTER=1/ENABLE_ODML_CONVERTER=0/g" setup.py && \
    rm -rf mediapipe/tasks/c/genai

# Analytics fake build
RUN mkdir -p mediapipe/util/analytics && \
printf 'package(default_visibility = ["//visibility:public"])\n\ncc_library(\n    name = "mediapipe_logging_enums_cc_proto",\n    hdrs = [],\n)\n\ncc_library(\n    name = "mediapipe_log_extension_cc_proto",\n    hdrs = [],\n)\n' \
> mediapipe/util/analytics/BUILD


RUN --mount=type=cache,target=/root/.cache/bazel \
    ln -sf $PYTHON_BIN /usr/bin/python && \
    ln -sf $PYTHON_BIN /usr/bin/python3 && \
    $PYTHON_BIN setup.py bdist_wheel clean --all

RUN auditwheel repair dist/*-cp312-cp312-linux_aarch64.whl


RUN mkdir /wheelhouse/ && cp dist/* /wheelhouse/
